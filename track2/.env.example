# Track 2 — local development environment variables
# Copy this file to .env and fill in your values.
# The submitted Docker image reads these purely from the environment — never bundle a .env file.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Fireworks AI API key (Track 2 uses your own credentials — no harness injection)
FIREWORKS_API_KEY=fw_your_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────

# Fireworks base URL (default: https://api.fireworks.ai/inference/v1)
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Vision model for the description pass (default: qwen3-vl-32b-instruct)
# Options: qwen3-vl-32b-instruct | qwen3-vl-8b-instruct | qwen2p5-vl-72b-instruct
# VISION_MODEL=accounts/fireworks/models/qwen3-vl-32b-instruct

# Text model for the caption pass (default: llama4-maverick-instruct-basic)
# "-basic" = free serverless tier of Llama 4 Maverick — confirmed live July 2026
# Options: llama4-maverick-instruct-basic | qwen3p7-plus
# TEXT_MODEL=accounts/fireworks/models/llama4-maverick-instruct-basic

# Whisper model size for audio transcription (default: tiny)
# Options: tiny | base | small — tiny is recommended for speed
# WHISPER_MODEL=tiny

# Set to "false" to skip audio transcription entirely (faster, slightly less accurate)
# ENABLE_WHISPER=true

# Global wall-clock budget in seconds (default: 520 = 8m40s, leaving 80s buffer)
# Reduce if you want a tighter safety margin
# TOTAL_BUDGET_SECS=520
