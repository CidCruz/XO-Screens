# Track 2 — local development environment variables
# Copy this file to .env and fill in your values.
# The submitted Docker image reads these purely from the environment — never bundle a .env file.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Fireworks AI API key (Track 2 uses your own credentials — no harness injection)
FIREWORKS_API_KEY=fw_your_api_key_here

# ── Optional overrides ────────────────────────────────────────────────────────

# Fireworks base URL (default: https://api.fireworks.ai/inference/v1)
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Vision model for the description pass — must be Vision-capable and serverless
# Default: minimax-m3 (MiniMax M3 — native multimodal, 512K context, confirmed available)
# Alternatives: qwen3p7-plus | kimi-k2p5
# VISION_MODEL=accounts/fireworks/models/minimax-m3

# Text model for the caption pass — needs strong instruction following
# Default: kimi-k2p5 (Kimi K2.6 — Function-calling, Tunable, 262K context, confirmed available)
# Alternatives: minimax-m3 | qwen3p7-plus | deepseek-v4-pro
# TEXT_MODEL=accounts/fireworks/models/kimi-k2p5

# Whisper model size for audio transcription (default: tiny)
# Options: tiny | base | small — tiny recommended (~4-10s per clip on CPU)
# WHISPER_MODEL=tiny

# Set to "false" to skip audio transcription entirely (faster, slightly less accurate)
# ENABLE_WHISPER=true

# Global wall-clock budget in seconds (default: 520 = 8m40s, leaving 80s buffer)
# TOTAL_BUDGET_SECS=520
