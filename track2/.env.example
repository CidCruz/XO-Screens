# Track 2 local development environment variables
# Copy this file to .env and fill in your values.
# The submitted Docker image reads these from the environment; never bundle a .env file.

# Required

# Your Fireworks AI API key for vision + caption generation
FIREWORKS_API_KEY=

# Optional overrides

# Fireworks base URL
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional path to model_config.json
# MODEL_CONFIG_PATH=model_config.json

# Vision model override for translating frames into a video translation file
# VISION_MODEL=accounts/fireworks/models/kimi-k2p6

# Process model override for turning the video translation file into captions
# PROCESS_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Directory for per-run token and credit usage JSON files
# USAGE_LOG_DIR=token/credits usage

# Global wall-clock budget in seconds
# TOTAL_BUDGET_SECS=520
