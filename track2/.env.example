# Track 2 — local development environment variables
# Copy this file to .env and fill in your values.
# The submitted Docker image reads these purely from the environment — never bundle a .env file.

# Required — your Fireworks AI API key
FIREWORKS_API_KEY=fw_your_api_key_here

# Optional — override the Fireworks base URL (default: https://api.fireworks.ai/inference/v1)
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional — override the vision model used for frame description
# VISION_MODEL=accounts/fireworks/models/qwen2p5-vl-72b-instruct

# Optional — override the text model used for caption generation
# TEXT_MODEL=accounts/fireworks/models/llama4-scout-instruct-basic
